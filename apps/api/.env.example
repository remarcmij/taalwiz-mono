# Taalwiz API environment.
# Copy this file to `.env` (same directory) and fill in the values.
# The server validates these on startup and refuses to boot if any required one is missing.

# --- App ---
NODE_ENV=development
# PORT is optional; defaults to 3000.
# PORT=3000

# Native (gloss) language for this deployment: `nl` for the Teeuw dictionary,
# `en` for the Stevens dictionary. Optional; defaults to `nl`. NOTE: this is read
# at WEB BUILD time (baked into the Angular bundle by
# apps/web/scripts/generate-deployment.mjs), not by the API at runtime — so the
# web app must be rebuilt for a change here to take effect.
# NATIVE_LANG=nl

# --- Database ---
# MongoDB connection string (the "taalwiz" database name is applied in code).
MONGO_URL=mongodb://localhost:27017

# --- Site / branding ---
SITE_NAME=Taalwiz
# Base URL of the web app; used to build activation and password-reset links.
HOST_URL=http://localhost:4200

# --- Email (SMTP, via Nodemailer) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# --- JWT secrets (use long, random strings; keep them distinct) ---
JWT_SECRET=
JWT_REFRESH_SECRET=

# --- Seed users (created on first startup) ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=
DEMO_EMAIL=demo@example.com
DEMO_PASSWORD=

# --- Custodian (institution contact; injected into emails) ---
CUSTODIAN_NAME=
CUSTODIAN_EMAIL=custodian@example.com
