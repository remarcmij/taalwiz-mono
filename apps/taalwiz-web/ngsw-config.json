{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.ico",
          "/index.html",
          "/manifest.webmanifest",
          "/*.css",
          "/*.js"
        ]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/assets/**",
          "/*.(svg|cur|jpg|jpeg|png|apng|webp|avif|gif|otf|ttf|woff|woff2)"
        ],
        "excludeFiles": [
          "/assets/dict-manifest.json",
          "/assets/*.*.json"
        ]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "content-api",
      "urls": ["/api/v1/content/**"],
      "cacheConfig": {
        "maxSize": 200,
        "maxAge": "14d",
        "timeout": "3s",
        "strategy": "freshness"
      }
    },
    {
      "name": "publication-images",
      "urls": ["/assets/images/*.(jpg|png)"],
      "cacheConfig": {
        "maxSize": 100,
        "maxAge": "7d",
        "timeout": "10s",
        "strategy": "performance"
      }
    }
  ]
}
